{
  "name": "agentboard",
  "version": "1.0.2",
  "description": "AI-powered business automation platform",
  "author": "AgentBoard",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "concurrently --kill-other-on-fail --names \"NEXT,ELECTRON\" --prefix-colors \"cyan,yellow\" \"next dev\" \"wait-on http://localhost:3000 && cross-env ELECTRON_DEV=1 NODE_ENV=development electron .\"",
    "electron:build": "next build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --publish never",
    "electron:build:win": "next build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --publish never",
    "electron:build:mac": "next build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --publish never",
    "electron:pack": "electron-builder --dir"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@react-pdf/renderer": "^4.3.2",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.1",
    "@types/papaparse": "^5.5.2",
    "electron-updater": "^6.8.3",
    "next": "^16.1.6",
    "papaparse": "^5.5.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.9.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.agentboard.app",
    "productName": "AgentBoard",
    "copyright": "Copyright © 2025 AgentBoard",
    "directories": {
      "output": "dist-electron",
      "buildResources": "public"
    },
    "files": [
      "electron/**/*",
      ".next/**/*",
      "public/**/*",
      "node_modules/**/*",
      "package.json",
      "next.config.ts"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icons/icon.png",
      "legalTrademarks": "AgentBoard",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AgentBoard"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "public/icons/icon.png",
      "category": "public.app-category.business",
      "darkModeSupport": true
    },
    "dmg": {
      "title": "AgentBoard",
      "background": null,
      "icon": "public/icons/icon.png",
      "iconSize": 80,
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icons/icon.png",
      "category": "Office"
    },
    "publish": {
      "provider": "github",
      "owner": "Crackdealer2001",
      "repo": "agentboard"
    }
  }
}
